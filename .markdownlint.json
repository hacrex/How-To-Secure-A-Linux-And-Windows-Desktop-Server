{
  "default": true,
  "extends": [
    "markdownlint-config-recommended"
  ],
  "rules": {
    "line-length": false,
    "no-inline-html": false,
    "first-line-h1": false,
    "single-h1": false,
    "no-duplicate-header": false,
    "no-emphasis-as-heading": false,
    "ol-prefix": false,
    "ul-style": {
      "style": "asterisk"
    },
    "MD013": false,
    "MD033": false,
    "MD041": false
  }
}
